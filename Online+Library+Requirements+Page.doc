<body>
    <h1>Online Library Requirements Page</h1>
    <div class=3D"Section1">
        <p>Online Library Requirements</p>
<ol>
 <li>Functional Requirements Document - Online Library Management System</l=
i>
</ol>
<p>=E2=80=94</p>
<h1><a name=3D"OnlineLibraryRequirementsPage-FunctionalRequirementsDocument=
"></a>Functional Requirements Document</h1>
<h2><a name=3D"OnlineLibraryRequirementsPage-OnlineLibraryManagementSystem"=
></a>Online Library Management System</h2>
<p>=E2=80=94</p>
<p><strong>Document Information</strong></p>
<table class=3D"confluenceTable">
 <tbody>
  <tr>
   <th class=3D"confluenceTh">
